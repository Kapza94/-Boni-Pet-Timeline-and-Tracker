# Supabase (F02)
# Local (after `supabase start`):
#   URL  = http://127.0.0.1:54321
#   KEY  = printed by `supabase start` as `anon key`
# Cloud:
#   URL  = https://<project>.supabase.co
#   KEY  = Project settings → API → anon/public key
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# StoreKit stub (F16). Set to 1 for dev builds so the paywall calls the
# dev-only stub purchase handler. MUST be unset/0 in production builds.
EXPO_PUBLIC_STOREKIT_STUB=1
