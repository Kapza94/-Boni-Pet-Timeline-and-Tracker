# Supabase (F02)
# Local (after `npx supabase start`, run `npx supabase status` to print):
#   URL  = http://127.0.0.1:54321
#   KEY  = `Publishable` key from the status output (sb_publishable_*)
# Cloud:
#   URL  = https://<project>.supabase.co
#   KEY  = Project settings → API → publishable / anon key
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secret key (Edge Functions, admin scripts).
# NEVER prefix with EXPO_PUBLIC_ — must not bundle into client.
SUPABASE_SECRET_KEY=

# StoreKit stub (F16). Set to 1 for dev builds so the paywall calls the
# dev-only stub purchase handler. MUST be unset/0 in production builds.
EXPO_PUBLIC_STOREKIT_STUB=1
